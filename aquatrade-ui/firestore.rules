rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    match /products/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /orders/{doc} {
      allow read, write: if request.auth.uid == resource.data.userId 
                         || request.auth != null;
    }
  }
}